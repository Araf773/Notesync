# ─────────────────────────────────────────────────────────────
# NoteSync — Firebase configuration
#
# Copy this file to `.env` and fill in the values from your
# Firebase project console:  Project settings → General →
# "Your apps" → SDK setup and configuration → Config.
#
# `.env` is git-ignored. NEVER commit real credentials.
#
# NOTE: These VITE_ vars are embedded in the client bundle at
# build time. That is expected and safe for Firebase web config
# (the API key is a project identifier, not a secret). Real
# security is enforced by Firestore Security Rules + Auth, not
# by hiding these values.
# ─────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# Optional: set to "true" to route all Firebase calls to local
# emulators (auth:9099, firestore:8080, storage:9199).
VITE_USE_FIREBASE_EMULATORS=false
