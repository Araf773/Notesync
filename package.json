{
  "name": "notesync",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "NoteSync — offline-first, multi-device note-taking app (web + Android via Capacitor)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "android:add": "cap add android",
    "android:build": "vite build && cap sync android && cd android && gradlew.bat assembleDebug"
  },
